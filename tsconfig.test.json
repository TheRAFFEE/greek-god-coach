{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".tmp-test",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["src/lib/**/*.ts"],
  "exclude": ["node_modules"]
}
